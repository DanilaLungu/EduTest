rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Проверка, авторизован ли пользователь
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Получение роли пользователя из коллекции users
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // 1. Коллекция пользователей
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // 2. Коллекция тестов и вложенных вопросов
    match /tests/{testId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && getUserData().role == 'teacher';
      
      match /questions/{questionId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && getUserData().role == 'teacher';
      }
    }

    // 3. Коллекция результатов тестирования (попыток)
    match /attempts/{attemptId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || getUserData().role == 'teacher');
    }
  }
}
